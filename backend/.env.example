# ═══════════════════════════════════════════
# DocsChat v4.1 环境变量模板 — 复制为 .env 并填入真实值
# ═══════════════════════════════════════════

# ── DeepSeek API ──
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Embedding ──
# chromadb_default: 内置 all-MiniLM-L6-v2 (384d)
# sentence_transformers: 本地 CrossEncoder (需 pip install sentence-transformers)
# remote: OpenAI-compatible API (vLLM/TGI)
EMBEDDING_PROVIDER=chromadb_default
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# 切换 BGE-M3 后必须清空并重建 ChromaDB
# BGE_M3_ENABLED=true
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_PROVIDER=remote
# EMBEDDING_API_BASE=http://localhost:8001/v1
# EMBEDDING_API_KEY=
# EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# ── MinerU 文档解析 ──
# pypdf: 纯文本兜底方案
# mineru: subprocess 调用 magic-pdf CLI
# mineru_api: HTTP API 调用远程 MinerU 服务
DOCUMENT_PARSER=pypdf
MINERU_ENABLED=false
MINERU_BACKEND=hybrid-auto-engine
MINERU_EFFORT=medium
# MinerU CLI 示例:
# MINERU_COMMAND=magic-pdf -p {input} -o {output} -m {backend} -l {effort}
# MinerU API 示例:
# MINERU_API_URL=http://mineru:8080
# MINERU_API_TIMEOUT=1800

# ── Reranker ──
# 本地: BAAI/bge-reranker-v2-m3 (sentence-transformers CrossEncoder)
# 远程: Qwen/Qwen3-Reranker-0.6B via vLLM
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANKER_MAX_LENGTH=2048
PRELOAD_RERANKER=false
# Qwen-Reranker 远程模式:
# QWEN_RERANKER_ENABLED=true
# RERANKER_API_URL=http://localhost:8002/v1
# RERANKER_API_TIMEOUT=30

# ── 质量门禁 ──
QG_ENABLED=true
QG_MIN_CHARS=100
QG_MIN_HEADINGS=0
QG_MIN_TABLES=0
QG_MIN_PAGES=1

# ── 在线 RAG 增强 ──
RAG_FUSION_VARIANTS=3
CRAG_ENABLED=true
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=86400
CHAT_MAX_CONCURRENT_LLM=8
INGESTION_MAX_CONCURRENT_JOBS=2

# ── SSE 安全与限流 ──
AUTH_REQUIRED=false
JWT_SECRET=
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# ── 服务 ──
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ═══════════════════════════════════════════
# v4.0 新增配置
# ═══════════════════════════════════════════

# ── URL 摄取 ──
WEB_INGEST_ENABLED=true
WEB_INGEST_MAX_PAGES=200
WEB_INGEST_MAX_DEPTH=3
WEB_INGEST_RESPECT_ROBOTS=true

# ── 代码感知分块 ──
CODE_AWARE_CHUNK_ENABLED=true

# ── 多库命名空间 ──
LIBRARY_FILTER_ENABLED=true

# ── 可观测 ──
METRICS_ENABLED=true

# ── 用户反馈 ──
FEEDBACK_ENABLED=true

# ── 在线 Demo 防护 ──
DEMO_API_KEY_REQUIRED=false
DEMO_API_KEY=
REDIS_URL=

# ═══════════════════════════════════════════
# v4.1 新增配置
# ═══════════════════════════════════════════

# ── 语义化查询分类 ──
QUERY_CLASSIFIER_FEW_SHOT_ENABLED=true
QUERY_CLASSIFIER_CACHE_ENABLED=true
QUERY_CLASSIFIER_CACHE_SIZE=200

# ── 代码子索引 ──
CODE_EMBEDDING_MODEL=

# ── Agentic 多跳检索 ──
MULTI_HOP_ENABLED=true
MULTI_HOP_MAX_SUB_QUERIES=3
